CREATE TABLE users (id uuid PRIMARY KEY, email text, created_at timestamptz DEFAULT now()); CREATE TABLE games (id uuid PRIMARY KEY, player1_id uuid REFERENCES users(id), player2_id uuid REFERENCES users(id), winner_id uuid REFERENCES users(id), status text, created_at timestamptz DEFAULT now()); CREATE TABLE game_moves (id uuid PRIMARY KEY, game_id uuid REFERENCES games(id), player_id uuid REFERENCES users(id), move_position integer, created_at timestamptz DEFAULT now());